# MongoDB Atlas Connection
# Get your connection string from: https://cloud.mongodb.com
# 1. Create a free cluster
# 2. Go to Database > Connect > Drivers
# 3. Copy the connection string and replace <password> with your password

MONGO_URI=mongodb+srv://your_username:your_password@your-cluster.mongodb.net/?retryWrites=true&w=majority&appName=OsteoAI
MONGO_DB_NAME=osteoai

# Gemini LLM Configuration
# Get your API key from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash
